# Public routing
NODE_ENV=production
APP_ENV=production
APP_DOMAIN=swarm.example.com
ACME_EMAIL=ops@example.com
PUBLIC_APP_URL=https://swarm.example.com
PUBLIC_API_URL=https://swarm.example.com
NEXT_PUBLIC_APP_URL=https://swarm.example.com
NEXT_PUBLIC_API_URL=https://swarm.example.com
INTERNAL_API_URL=http://api:8000

# Session and browser policy
SESSION_COOKIE_NAME=swarm_session_token
SESSION_COOKIE_DOMAIN=swarm.example.com
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
METRICS_ENABLED=true
SSO_GOOGLE_CLIENT_ID=
SSO_MICROSOFT_CLIENT_ID=
SSO_OIDC_CLIENT_ID=
SSO_OIDC_ISSUER_URL=
SSO_SAML_ENTITY_ID=
SSO_SAML_SSO_URL=

# Alibaba Model Access
ALIBABA_API_KEY=replace-with-real-key
ALIBABA_API_HOST=ws-pq02hrwmtnk68klo.eu-central-1.maas.aliyuncs.com
ALIBABA_OPENAI_BASE_URL=https://ws-pq02hrwmtnk68klo.eu-central-1.maas.aliyuncs.com/compatible-mode/v1
ALIBABA_DASHSCOPE_URL=https://ws-pq02hrwmtnk68klo.eu-central-1.maas.aliyuncs.com/api/v1

# Backend
APP_NAME=Autonomous AI Swarm
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=480
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_DB=autonomous_ai_swarm
DATABASE_URL=postgresql+psycopg://postgres:change-me-db-password@postgres:5432/autonomous_ai_swarm
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:change-me-db-password@postgres:5432/autonomous_ai_swarm
REDIS_URL=redis://redis:6379/0
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=swarmminio
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=artifacts
ENABLE_SIGNUPS=true
ENABLE_DEMO_MODE=false
ALLOW_LOCAL_PROVIDER_FALLBACK=false
AUTO_CREATE_TABLES=false
CORS_ORIGINS=https://swarm.example.com
TRUSTED_HOSTS=swarm.example.com,localhost,127.0.0.1,api
DEFAULT_ORGANIZATION_NAME=Production Organization
DEFAULT_WORKSPACE_NAME=Operations
DEMO_USER_EMAIL=disabled@example.com
DEMO_USER_PASSWORD=disabled
SESSION_TTL_HOURS=168
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=90
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_BURST_REQUESTS=30
REQUEST_TELEMETRY_RETENTION=500
PRODUCTION_BACKUP_MAX_AGE_HOURS=30
SECRET_ROTATION_INTERVAL_DAYS=90
SSL_MIN_VALID_DAYS=21
ALERT_WEBHOOK_URL=
PROVIDER_BUDGET_ENFORCED=true
PROVIDER_BUDGET_WINDOW_HOURS=24
PROVIDER_DAILY_COST_CAP_USD=50.0
PROVIDER_BUDGET_ALERT_THRESHOLD=0.8
EMBEDDING_MODEL=text-embedding-placeholder
EMBEDDING_DIMENSIONS=1536
RETRIEVAL_KEYWORD_WEIGHT=0.45
RETRIEVAL_VECTOR_WEIGHT=0.55
RETRIEVAL_TRUST_WEIGHT=0.12
RETRIEVAL_FRESHNESS_WEIGHT=0.08
RETRIEVAL_MAX_CANDIDATES=128
RETRIEVAL_DEFAULT_LIMIT=8
RETRIEVAL_MAX_CHUNKS_PER_DOCUMENT=2
AUTOMATION_SCHEDULER_ENABLED=true
AUTOMATION_POLL_INTERVAL_SECONDS=20
AUTOMATION_DEFAULT_RETRY_LIMIT=2
AUTOMATION_DEFAULT_TIMEOUT_SECONDS=900
AUTOMATION_RETRY_BACKOFF_SECONDS=45
AUTOMATION_NOTIFICATION_HISTORY_LIMIT=12
EXTERNAL_REQUEST_TIMEOUT_SECONDS=15
BROWSER_ENABLED=true
BROWSER_HEADLESS=true
BROWSER_NAVIGATION_TIMEOUT_MS=15000
BROWSER_ACTION_TIMEOUT_MS=6000
BROWSER_CAPTURE_SCREENSHOT=true
BROWSER_CAPTURE_HTML=true
BROWSER_CAPTURE_TEXT_CHARS=4000
BROWSER_CAPTURE_MAX_LINKS=8
EMAIL_FROM_NAME=Autonomous AI Swarm
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=false
SMTP_STARTTLS=true
RESEND_API_KEY=
RESEND_BASE_URL=https://api.resend.com
SLACK_BOT_TOKEN=
SLACK_WEBHOOK_URL=
SLACK_API_BASE_URL=https://slack.com/api
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_BASE_URL=https://www.googleapis.com/calendar/v3
MICROSOFT_GRAPH_ACCESS_TOKEN=
MICROSOFT_CALENDAR_ID=primary
MICROSOFT_GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
SUPERVISOR_MODEL=qwen3.5-flash
RESEARCH_MODEL_FAST=qwen3.5-flash
RESEARCH_MODEL_SLOW=qwen3.6-plus
ANALYSIS_MODEL_FAST=qwen3.5-flash
ANALYSIS_MODEL_SLOW=qwen3-max
CONTENT_MODEL_FAST=qwen3.5-flash
CONTENT_MODEL_SLOW=qwen3.5-plus
CODING_MODEL_FAST=qwen3-coder-flash
CODING_MODEL_SLOW=qwen3-coder-plus
VISION_MODEL_FAST=qwen3-vl-flash
VISION_MODEL_SLOW=qwen3-vl-plus
